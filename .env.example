# ── Railway environment variables ──────────────────────────────────────────────
# Copy to .env for local dev (never commit .env)

# Domain — "miragestudios.io" in prod; unset for local (uses .localhost suffix)
ROOT_DOMAIN=miragestudios.io

# Long random secret for signing auth cookies and preview tokens
SESSION_SECRET=change-me-to-a-long-random-string

# Password for admin.miragestudios.io
ADMIN_PASSWORD=change-me

# Anthropic API key — powers AI draft generation in the admin editor
ANTHROPIC_API_KEY=sk-ant-...

# Railway sets this automatically; DATA_DIR is where the SQLite DB + uploads live.
# On Railway, mount a Volume at /data and set: DATA_DIR=/data
DATA_DIR=/data

# Set by Railway automatically
# PORT=3000
